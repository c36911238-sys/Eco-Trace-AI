# ────────────────────────────────────────────────────────────────────────────
# EcoTrace AI+ — Backend Environment Variables
# Copy this file to .env and fill in the values. NEVER commit .env to git.
# ────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
PROJECT_NAME=EcoTrace AI+

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8 hours

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example for production: https://app.ecotrace.ai,https://ecotrace.ai
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev):
SQLALCHEMY_DATABASE_URI=sqlite+aiosqlite:///./ecotrace.db
# PostgreSQL (production with Supabase/Railway):
# SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

# Set to True only for local debugging of slow queries:
DB_ECHO=False

# ── OCR Driver ────────────────────────────────────────────────────────────────
# Options: "mock" (default, deterministic) | "google_vision" (production)
OCR_DRIVER=mock

# ── Google Cloud (required if OCR_DRIVER=google_vision) ──────────────────────
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
